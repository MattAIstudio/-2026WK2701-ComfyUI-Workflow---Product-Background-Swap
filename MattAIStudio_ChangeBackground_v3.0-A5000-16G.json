&R": "VRAM_Debug"}, "widgets_values": [true, true, true], "title": "VRAM清理 (采样前)", "color": "#322", "bgcolor": "#533"}, {"id": 280, "type": "KSampler", "pos": [2380.0, 1014], "size": [320, 340], "flags": {"collapsed": false}, "order": 20, "mode": 0, "inputs": [{"localized_name": "模型", "name": "model", "type": "MODEL", "link": 460}, {"localized_name": "正面条件", "name": "positive", "type": "CONDITIONING", "link": 461}, {"localized_name": "负面条件", "name": "negative", "type": "CONDITIONING", "link": 462}, {"localized_name": "Latent", "name": "latent_image", "type": "LATENT", "link": 463}], "outputs": [{"localized_name": "Latent", "name": "LATENT", "type": "LATENT", "slot_index": 0, "links": [464]}], "title": "KSampler (集成采样器)", "properties": {"cnr_id": "comfy-core", "ver": "0.8.2", "Node name for S&R": "KSampler"}, "widgets_values": [1063717354702968, "randomize", 6, 1, "euler", "simple", 1.0], "color": "#432", "bgcolor": "#653"}, {"id": 281, "type": "MarkdownNote", "pos": [60, 20], "size": [980, 800], "flags": {}, "order": 0, "mode": 0, "inputs": [], "outputs": [], "title": "📌 工作流说明 / README", "properties": {}, "widgets_values": ["# 🎨 AI 产品换背景工作流 v3.0\n# AI Product Background Replacement\n\n**创作者 / Creator:** MattAIstudio　|　**YouTube:** https://www.youtube.com/@MattAIstudio\n\n---\n## 🖥️ 设备 / Device\n**机型:** RTX A5000 Laptop · **16GB VRAM** · 建议 RAM ≥ 32GB\n**省显存策略 / Low-VRAM:** 文本编码器→CPU · UNET `fp8_e4m3fn` · 分辨率上限 1024 · 采样前 VRAM 清理(unload)\n\n> 启动建议: `python main.py --reserve-vram 0.6`（仍 OOM 再加 `--lowvram`）\n\n## 🧩 功能简介 / Overview\n保持产品主体不变，自动抠图后用 **FLUX.2 Klein** 重绘背景，输出商用级场景图。\nKeeps the product subject fixed, removes its background, then regenerates a new scene with FLUX.2 Klein.\n\n## 📦 模型与下载 / Models & Downloads\n| 模型 Model | 目录 Folder | 下载 Download |\n|---|---|---|\n| flux-2-klein-9b-fp8 *(蒸馏/distilled)* | `diffusion_models` | https://huggingface.co/black-forest-labs/FLUX.2-klein-9b-fp8 |\n| qwen_3_8b_fp8mixed | `text_encoders` | https://huggingface.co/Comfy-Org/flux2-klein-9B |\n| flux2-vae | `vae` | https://huggingface.co/Comfy-Org/flux2-dev |\n| RMBG-2.0 | `models/RMBG` | https://huggingface.co/1038lab/RMBG-2.0 |\n\n> ⚠️ **步数说明 / Steps:** 9b-fp8 是**蒸馏版(4步)**模型 → KSampler 步数 **4–6**、CFG **1.0** 即可，步数越高≠越好。\n> 想要 20–30 步的高步数画质，请改用 base 版：`flux-2-klein-base-9b-fp8`。\n\n## 🎨 颜色分组 / Color Groups（自左向右执行 / left → right）\n| 颜色 Color | 分组 Group |\n|---|---|\n| 🟣 紫 Purple | 模型加载 Loaders |\n| 🔵 蓝 Blue | 输入图像 Input |\n| 🟦 青 Teal | 抠图·铺底 BG Removal |\n| 🟠 橙 Orange | 提示词·条件 Prompt |\n| 🫒 橄榄 Olive | 编码·参考潜空间 Encode |\n| 🔴 红 Red | 采样 KSampler |\n| 🟢 绿 Green | 输出·对比 Output |\n"], "color": "#322653", "bgcolor": "#22184a"}], "links": [[426, 261, 0, 253, 0, "CONDITIONING"], [427, 252, 0, 254, 0, "STRING"], [428, 273, 0, 254, 1, "STRING"], [429, 261, 0, 255, 0, "CONDITIONING"], [430, 258, 0, 255, 1, "LATENT"], [431, 267, 0, 258, 0, "IMAGE"], [432, 270, 0, 258, 1, "VAE"], [433, 253, 0, 259, 0, "CONDITIONING"], [434, 258, 0, 259, 1, "LATENT"], [436, 257, 0, 261, 0, "CLIP"], [437, 254, 0, 261, 1, "STRING"], [448, 275, 0, 267, 0, "IMAGE"], [449, 266, 0, 267, 9, "COLORCODE"], [452, 270, 0, 269, 1, "VAE"], [453, 269, 0, 271, 0, "IMAGE"], [454, 274, 0, 272, 0, "IMAGE"], [455, 269, 0, 272, 1, "IMAGE"], [456, 274, 0, 275, 0, "IMAGE"], [457, 258, 0, 276, 0, "LATENT"], [460, 256, 0, 280, 0, "MODEL"], [461, 255, 0, 280, 1, "CONDITIONING"], [462, 259, 0, 280, 2, "CONDITIONING"], [463, 276, 0, 280, 3, "LATENT"], [464, 280, 0, 269, 0, "LATENT"]], "groups": [{"id": 1, "title": "📦 模型加载  Loaders", "bounding": [60, 940, 432, 444], "color": "#5a3f9e", "font_size": 24, "flags": {}}, {"id": 2, "title": "🖼️ 输入图像  Input", "bounding": [530, 940, 412, 686], "color": "#3f789e", "font_size": 24, "flags": {}}, {"id": 3, "title": "✂️ 抠图·铺底  BG Removal", "bounding": [980, 940, 412, 524], "color": "#2f7f7f", "font_size": 24, "flags": {}}, {"id": 4, "title": "✍️ 提示词·条件  Prompt", "bounding": [1430, 940, 502, 996], "color": "#a6712e", "font_size": 24, "flags": {}}, {"id": 5, 